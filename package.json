{
  "name": "bar-backend",
  "version": "1.0.0",
  "description": "Offline-first cashier backend with sync and multi-tenant support",
  "main": "backend/dist/server.js",
  "scripts": {
    "dev": "tsx watch backend/src/server.ts",
    "build": "tsc -p backend/tsconfig.json",
    "start": "node backend/dist/server.js",
    "check": "tsc --noEmit -p backend/tsconfig.json",
    "test": "tsc -p backend/tsconfig.json && node backend/dist/tests/business-rules.test.js"
  },
  "keywords": [
    "express",
    "mongoose",
    "mongodb",
    "offline-first",
    "sync"
  ],
  "license": "MIT",
  "dependencies": {
    "@types/morgan": "^1.9.10",
    "bcryptjs": "^2.4.3",
    "body-parser": "^2.2.2",
    "cors": "^2.8.6",
    "dotenv": "^16.4.5",
    "express": "^4.22.1",
    "helmet": "^8.0.0",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^8.19.3",
    "morgan": "^1.10.1",
    "node-cron": "^4.2.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/node": "^22.10.2",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
