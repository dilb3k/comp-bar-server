{
  "info": {
    "name": "Bar Backend API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Auth Register",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "url": "{{baseUrl}}/auth/register",
        "body": {
          "mode": "raw",
          "raw": "{\n  \"workspaceName\": \"Cyber Club A\",\n  \"name\": \"Owner\",\n  \"email\": \"owner@club.com\",\n  \"password\": \"secret123\"\n}"
        }
      }
    },
    {
      "name": "Auth Login",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "url": "{{baseUrl}}/auth/login",
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"owner@club.com\",\n  \"password\": \"secret123\"\n}"
        }
      }
    },
    {
      "name": "Create Product",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          },
          {
            "key": "Authorization",
            "value": "Bearer {{token}}"
          }
        ],
        "url": "{{baseUrl}}/products",
        "body": {
          "mode": "raw",
          "raw": "{\n  \"name\": \"Energy Drink\",\n  \"costPrice\": 0.6,\n  \"sellPrice\": 1.2,\n  \"initialStock\": 100\n}"
        }
      }
    },
    {
      "name": "Push Sync",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          },
          {
            "key": "Authorization",
            "value": "Bearer {{token}}"
          }
        ],
        "url": "{{baseUrl}}/sync",
        "body": {
          "mode": "raw",
          "raw": "{\n  \"deviceId\": \"device-01\",\n  \"actions\": [\n    {\n      \"type\": \"CREATE_SALE\",\n      \"data\": {\n        \"id\": \"3017c9a4-57d2-4f70-a2ae-e9fbb4b778c5\",\n        \"productId\": \"{{productId}}\",\n        \"quantity\": 2,\n        \"createdAt\": \"2026-04-03T08:30:00.000Z\"\n      }\n    }\n  ]\n}"
        }
      }
    },
    {
      "name": "Pull Sync",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{token}}"
          }
        ],
        "url": "{{baseUrl}}/sync?lastSync=2026-04-03T00:00:00.000Z&page=1&pageSize=100"
      }
    },
    {
      "name": "Stats Summary",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{token}}"
          }
        ],
        "url": "{{baseUrl}}/stats/summary?dateFrom=2026-04-01T00:00:00.000Z&dateTo=2026-04-30T23:59:59.999Z"
      }
    }
  ],
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:4000/api"
    },
    {
      "key": "token",
      "value": ""
    },
    {
      "key": "productId",
      "value": ""
    }
  ]
}
